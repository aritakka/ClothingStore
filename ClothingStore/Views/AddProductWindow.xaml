<Window x:Class="ClothingStore.Views.AddProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Product" Height="340" Width="420" ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary Source="../Resources/Styles.xaml"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Name" />
        <TextBox Name="txtName" Grid.Row="1" Height="28" Margin="0,4,0,8"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,8">
            <StackPanel Width="240">
                <TextBlock Text="Size" />
                <TextBox Name="txtSize" Height="28" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Width="140" Margin="12,0,0,0">
                <TextBlock Text="Price" />
                <TextBox Name="txtPrice" Height="28" Margin="0,4,0,0"/>
            </StackPanel>
        </StackPanel>

        <TextBlock Text="Image path (optional)" Grid.Row="3"/>
        <TextBox Name="txtImage" Grid.Row="4" Height="28" Margin="0,4,0,0"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0" Grid.Row="5">
            <Button Name="btnSave" Click="BtnSave_Click" Content="Save" Width="100" Margin="0,0,8,0" Style="{StaticResource PrimaryButton}"/>
            <Button Click="BtnCancel_Click" Content="Cancel" Width="90" Style="{StaticResource SecondaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
