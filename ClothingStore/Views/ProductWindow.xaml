<Window x:Class="ClothingStore.Views.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ClothingStore.Views.Controls"
        xmlns:models="clr-namespace:ClothingStore.Models"
        Title="Products" Height="520" Width="900" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary Source="../Resources/Styles.xaml"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
            <Button Name="btnAdd" Content="Add product" Click="BtnAdd_Click" Width="110" Margin="0,0,8,0" Style="{StaticResource PrimaryButton}"/>
            <Button Content="Refresh" Click="BtnRefresh_Click" Width="90" Style="{StaticResource SecondaryButton}"/>
        </StackPanel>

        <ListView Name="lvProducts" Grid.Row="1" ItemsSource="{Binding}">
            <ListView.ItemTemplate>
                <DataTemplate DataType="{x:Type models:Product}">
                    <controls:ProductCard/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
