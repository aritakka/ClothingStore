<UserControl x:Class="ClothingStore.Views.Controls.ProductCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:ClothingStore.Models"
             xmlns:conv="clr-namespace:ClothingStore.Converters"
             Height="100" Width="Auto" Margin="0,4,0,4">

    <UserControl.Resources>
        <!-- Конвертер для корректной обработки null и пустых ImagePath -->
        <conv:NullableImageConverter x:Key="NullableImageConverter"/>
    </UserControl.Resources>

    <Border CornerRadius="6" BorderBrush="#DDD" BorderThickness="1" Padding="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Изображение с конвертером -->
            <Image Width="88" Height="88" Stretch="Uniform"
                   Source="{Binding ImagePath, Converter={StaticResource NullableImageConverter}}">
                <Image.Style>
                    <Style TargetType="Image">
                        <Style.Triggers>
                            <!-- Скрываем картинку, если ImagePath = null или пустой -->
                            <DataTrigger Binding="{Binding ImagePath}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>

            <StackPanel Grid.Column="1" Margin="8,0,8,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                <TextBlock Text="{Binding Size}" Foreground="Gray"/>
            </StackPanel>

            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                <TextBlock Text="{Binding Price, StringFormat=C}" FontWeight="Bold" HorizontalAlignment="Right"/>
                <Button Content="Add" Width="60" Margin="0,8,0,0" Click="BtnAdd_Click" Style="{StaticResource PrimaryButton}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>