<Window x:Class="ClothingStore.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Register" Height="320" Width="360" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary Source="Resources/Styles.xaml"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Full name" />
        <TextBox Name="txtFullName" Grid.Row="1" Height="28" Margin="0,4,0,8"/>
        <TextBlock Text="Email" Grid.Row="2" />
        <TextBox Name="txtEmail" Grid.Row="3" Height="28" Margin="0,4,0,8"/>
        <TextBlock Text="Password" Grid.Row="4" />
        <PasswordBox Name="txtPassword" Grid.Row="5" Height="28" Margin="0,4,0,8"/>
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Name="btnRegister" Click="BtnRegister_Click" Content="Register" Width="100" Style="{StaticResource PrimaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
